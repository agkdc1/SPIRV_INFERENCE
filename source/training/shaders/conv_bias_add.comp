#version 450
layout(local_size_x = 128) in;
layout(std430, binding = 0) readonly buffer A { float input_data[]; };
layout(std430, binding = 1) readonly buffer B { float bias[]; };
layout(std430, binding = 2) writeonly buffer C { float output_data[]; };
layout(push_constant) uniform P { int total; int C; int HW; } pc;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(pc.total)) return;
    int c = (int(i) / pc.HW) % pc.C;
    output_data[i] = input_data[i] + bias[c];
}
