#version 450
layout(local_size_x = 128) in;
layout(std430, binding = 0) readonly buffer A { float sm_out[]; };
layout(std430, binding = 1) readonly buffer B { float target[]; };
layout(std430, binding = 2) writeonly buffer C { float grad[]; };
layout(push_constant) uniform P { int total; int batch_size; } pc;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(pc.total)) return;
    grad[i] = (sm_out[i] - target[i]) / float(pc.batch_size);
}
