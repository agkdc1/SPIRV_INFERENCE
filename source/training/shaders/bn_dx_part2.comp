#version 450
layout(local_size_x = 128) in;
layout(std430, binding = 0) readonly buffer A { float dY[]; };
layout(std430, binding = 1) readonly buffer B { float scratch[]; };
layout(std430, binding = 2) writeonly buffer C { float prescale[]; };
layout(push_constant) uniform P { int total; int m; } pc;
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i >= uint(pc.total)) return;
    prescale[i] = float(pc.m) * dY[i] - scratch[i];
}
