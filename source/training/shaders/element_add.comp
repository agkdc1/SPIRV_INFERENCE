#version 450
layout(local_size_x = 128) in;
layout(std430, binding = 0) readonly buffer A { float a_data[]; };
layout(std430, binding = 1) readonly buffer B { float b_data[]; };
layout(std430, binding = 2) writeonly buffer C { float output_data[]; };
layout(push_constant) uniform P {
    int total;
} pc;
void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= uint(pc.total)) return;
    output_data[idx] = a_data[idx] + b_data[idx];
}
