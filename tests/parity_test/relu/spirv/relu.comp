#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(set = 0, binding = 0) readonly buffer InBuf { float x[]; };
layout(set = 0, binding = 2) writeonly buffer OutBuf { float y[]; };
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < 4096u) {
        float v = x[i];
        y[i] = v > 0.0 ? v : 0.0;
    }
}
