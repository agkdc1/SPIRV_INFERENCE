#version 450
layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;
layout(set = 0, binding = 0) readonly buffer InBuf { float x[]; };
layout(set = 0, binding = 1) readonly buffer ParamBuf { float p[]; };
layout(set = 0, binding = 2) writeonly buffer OutBuf { float y[]; };
void main() {
    uint i = gl_GlobalInvocationID.x;
    if (i < 256u) {
        float mean = p[0];
        float variance = p[1];
        float gamma = p[2];
        float beta = p[3];
        float eps = p[4];
        y[i] = ((x[i] - mean) / sqrt(variance + eps)) * gamma + beta;
    }
}
